---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  section?: 'japo' | 'abu-dhabi' | '';
}
const { title, description = 'Guia de viatge personal', section = '' } = Astro.props;
---
<!doctype html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title} — dimoni.cat</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <header style="border-bottom: 1px solid var(--color-border); position: sticky; top: 0; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); z-index: 50;">
      <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 3.5rem;">
        <a href="/" style="font-weight: 800; font-size: 1rem; letter-spacing: -0.03em;">
          dimoni<span class="accent">.</span>cat
        </a>
        <nav style="display: flex; gap: 2rem; align-items: center;">
          <a
            href="/japo"
            class:list={['label', { accent: section === 'japo' }]}
            style="font-size: 0.6875rem;"
          >Japó 2026</a>
          <a
            href="/abu-dhabi"
            class:list={['label', { accent: section === 'abu-dhabi' }]}
            style="font-size: 0.6875rem;"
          >Abu Dhabi</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer style="border-top: 1px solid var(--color-border); margin-top: 6rem;">
      <div class="container" style="display: flex; align-items: center; justify-content: space-between; padding-top: 1.5rem; padding-bottom: 1.5rem;">
        <span class="label">dimoni.cat</span>
        <span class="label" id="jpy-rate" style="font-style: italic;">viatge 2026</span>
      </div>
    </footer>

    <script>
    (async function () {
      let rate: number | null = null;

      // Cache per sessió (1 hora)
      const cached = sessionStorage.getItem('jpy_eur');
      if (cached) {
        const { r, ts } = JSON.parse(cached);
        if (Date.now() - ts < 3_600_000) rate = r;
      }

      if (!rate) {
        try {
          const res = await fetch('https://api.frankfurter.app/latest?from=JPY&to=EUR');
          const data = await res.json();
          rate = data.rates.EUR as number;
          sessionStorage.setItem('jpy_eur', JSON.stringify({ r: rate, ts: Date.now() }));
        } catch {
          return;
        }
      }

      const fmt = new Intl.NumberFormat('ca-ES', { maximumFractionDigits: 0 });
      const toEur = (yen: string) => fmt.format(Math.round(parseInt(yen.replace(/,/g, '')) * rate!));

      const blocked = new Set(['SCRIPT', 'STYLE', 'NOSCRIPT', 'TITLE', 'CODE', 'PRE']);
      const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
      const nodes: Text[] = [];
      let n: Node | null;
      while ((n = walker.nextNode())) {
        const tn = n as Text;
        if (!blocked.has(tn.parentElement?.tagName ?? '') && tn.textContent?.includes('¥')) {
          nodes.push(tn);
        }
      }

      for (const tn of nodes) {
        const orig = tn.textContent ?? '';
        const html = orig.replace(/¥([\d,]+)(?:[-–]([\d,]+))?/g, (_m, a, b) => {
          if (b) {
            return `¥${a}–${b}<span class="eur-eq">≈ €${toEur(a)}–€${toEur(b)}</span>`;
          }
          return `¥${a}<span class="eur-eq">≈ €${toEur(a)}</span>`;
        });
        if (html !== orig) {
          const span = document.createElement('span');
          span.innerHTML = html;
          tn.parentElement?.replaceChild(span, tn);
        }
      }

      const rateEl = document.getElementById('jpy-rate');
      if (rateEl) {
        const eurPer1000 = ((rate ?? 0) * 1000).toFixed(2);
        rateEl.textContent = `¥1.000 = €${eurPer1000} · cotització en viu`;
      }
    })();
    </script>
  </body>
</html>
