---
import Layout from '../layouts/Layout.astro';

const destinations = [
  {
    href: '/japo',
    dates: '23 juliol – 14 agost 2026',
    title: 'Japó',
    desc: "Ruta, hotels, compres, akiya, vehicles JDM, inversió i fiscalitat des d'Espanya.",
  },
  {
    href: '/abu-dhabi',
    dates: '24 – 25 juliol 2026',
    title: 'Abu Dhabi',
    desc: 'Escala de dos dies. Llocs a visitar, oportunitats de compra i negoci.',
  },
];
---

<Layout title="Inici" description="Guia personal de viatge i recursos">
  <div class="container hero">

    <div class="intro">
      <p class="label">Guia personal</p>
      <h1>Viatges <span class="accent">&</span><br/>recursos</h1>
      <p class="intro-desc">Notes, guies i informació útil per als propers viatges. Públic però personal.</p>
    </div>

    <div class="dest-grid">
      {destinations.map(({ href, dates, title, desc }) => (
        <a href={href} class="card dest-card">
          <div>
            <p class="label">{dates}</p>
            <h2>{title}</h2>
            <p class="card-desc">{desc}</p>
          </div>
          <span class="label cta">Veure guia →</span>
        </a>
      ))}
    </div>

  </div>
</Layout>

<style>
  .hero {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .intro {
    margin-bottom: 5rem;
  }

  .intro .label {
    margin-bottom: 1.5rem;
  }

  .intro h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    margin-bottom: 1.5rem;
  }

  .intro-desc {
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 480px;
  }

  .dest-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
  }

  .dest-card {
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 260px;
    gap: 0;
  }

  .dest-card .label {
    margin-bottom: 1.25rem;
  }

  .dest-card h2 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .card-desc {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .cta {
    color: var(--color-accent);
    margin-top: 2rem;
  }
</style>
