---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Inici" description="Guia personal de viatge i recursos">
  <div class="container" style="padding-top: 6rem; padding-bottom: 6rem;">

    <div style="margin-bottom: 5rem;">
      <p class="label" style="margin-bottom: 1.5rem;">Guia personal</p>
      <h1 style="font-size: clamp(3rem, 8vw, 5.5rem); margin-bottom: 1.5rem;">
        Viatges <span class="accent">&</span><br/>recursos
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-muted); max-width: 480px;">
        Notes, guies i informació útil per als propers viatges. Públic però personal.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border);">

      <a href="/japo" class="card" style="background: var(--color-bg); gap: 0; display: flex; flex-direction: column; justify-content: space-between; min-height: 260px;">
        <div>
          <p class="label" style="margin-bottom: 1.25rem;">23 juliol – 14 agost 2026</p>
          <h2 style="font-size: 2.5rem; margin-bottom: 0.75rem;">Japó</h2>
          <p style="color: var(--color-muted); font-size: 0.9375rem; line-height: 1.6;">
            Ruta, hotels, compres, akiya, vehicles JDM, inversió i fiscalitat des d'Espanya.
          </p>
        </div>
        <span class="label" style="color: var(--color-accent); margin-top: 2rem;">Veure guia →</span>
      </a>

      <a href="/abu-dhabi" class="card" style="background: var(--color-bg); display: flex; flex-direction: column; justify-content: space-between; min-height: 260px;">
        <div>
          <p class="label" style="margin-bottom: 1.25rem;">24 – 25 juliol 2026</p>
          <h2 style="font-size: 2.5rem; margin-bottom: 0.75rem;">Abu Dhabi</h2>
          <p style="color: var(--color-muted); font-size: 0.9375rem; line-height: 1.6;">
            Escala de dos dies. Llocs a visitar, oportunitats de compra i negoci.
          </p>
        </div>
        <span class="label" style="color: var(--color-accent); margin-top: 2rem;">Veure guia →</span>
      </a>

    </div>

  </div>
</Layout>
