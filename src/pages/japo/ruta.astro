---
import Layout from '../../layouts/Layout.astro';

const etapes = [
  {
    data: "23 jul",
    lloc: "Barcelona → Abu Dhabi",
    tipus: "trànsit",
    notes: "Vol BCN-AUH. Etihad o Emirates. Sortida habitualment a la nit."
  },
  {
    data: "24–25 jul",
    lloc: "Abu Dhabi",
    tipus: "escala",
    notes: "Dos dies per visitar la ciutat. Gran Mesquita, Louvre Abu Dhabi, Corniche. Calor extrem (45–50°C), planificar activitats d'interior."
  },
  {
    data: "25 jul (nit)",
    lloc: "Abu Dhabi → Tokyo",
    tipus: "trànsit",
    notes: "Vol nocturn AUH-NRT o AUH-HND. ~9h de vol. Arriba matí del 26."
  },
  {
    data: "26–31 jul",
    lloc: "Tokyo",
    tipus: "destinació",
    notes: "6 nits a Tokyo. Base per explorar Shinjuku, Shibuya, Asakusa, Akihabara, Yanaka. Excursió opcional a Nikko o Kamakura (dia sencer)."
  },
  {
    data: "1 ago",
    lloc: "Nikko o Kamakura",
    tipus: "excursió",
    notes: "Nikko: temples i naturalesa espectacular, 2h amb tren des de Tokyo. Kamakura: Buda gegant i temples budistes, 1h des de Tokyo. Millor Nikko per la grandiositat."
  },
  {
    data: "2–5 ago",
    lloc: "Kyoto",
    tipus: "destinació",
    notes: "4 nits. Shinkansen Nozomi des de Tokyo (2h15). Gion, Fushimi Inari, Arashiyama, Kinkaku-ji. Excursió a Nara (45 min en tren, cérvols i temples)."
  },
  {
    data: "6–8 ago",
    lloc: "Osaka",
    tipus: "destinació",
    notes: "3 nits. 15 min des de Kyoto amb Shinkansen. Dotonbori, Namba, Den Den Town (electrònica), Osaka Castle. Gastronomia: takoyaki, okonomiyaki, ramen."
  },
  {
    data: "9 ago",
    lloc: "Hiroshima + Miyajima",
    tipus: "excursió",
    notes: "Dia complet. Shinkansen des d'Osaka (45 min). Memorial de la Pau, Museu Atòmic. Ferry a l'illa de Miyajima: torii flotant de l'shrine d'Itsukushima."
  },
  {
    data: "10–13 ago",
    lloc: "Tokyo",
    tipus: "destinació",
    notes: "Retorn a Tokyo (Shinkansen desde Hiroshima ~4h). 4 últimes nits: compres a Ginza, visita barris que han quedat, gastronomia pendents. Preparació de l'equipatge per la tornada."
  },
  {
    data: "14 ago",
    lloc: "Tokyo → Barcelona",
    tipus: "trànsit",
    notes: "Sortida NRT o HND. Vol de tornada via Abu Dhabi o directe segons disponibilitat."
  }
];
---
<Layout title="Ruta" description="Recorregut complet del viatge al Japó" section="japo">
  <div class="container" style="padding-top: 4rem; padding-bottom: 6rem;">

    <nav style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 3rem; font-size: 0.8125rem; color: var(--color-muted);">
      <a href="/japo" style="color: var(--color-muted);">Japó</a>
      <span>→</span>
      <span style="color: var(--color-fg);">Ruta</span>
    </nav>

    <p class="label" style="margin-bottom: 1.25rem;">23 juliol – 14 agost 2026 · 23 dies</p>
    <h1 style="font-size: clamp(2.5rem, 7vw, 4.5rem); margin-bottom: 1.5rem;">Ruta</h1>
    <p style="font-size: 1.0625rem; color: var(--color-muted); max-width: 540px; margin-bottom: 3rem;">
      Ruta circular Barcelona → Abu Dhabi → Tokyo → Kyoto → Osaka → Tokyo → Barcelona. Transport intern principal: JR Pass.
    </p>

    <div class="info-block" style="margin-bottom: 3rem;">
      <p style="font-size: 0.9375rem; font-weight: 600; margin-bottom: 0.375rem;">JR Pass — Comprar abans de sortir</p>
      <p style="font-size: 0.875rem; color: var(--color-muted);">
        El Japan Rail Pass cobreix tots els Shinkansen (menys Nozomi i Mizuho en 7-day pass), metros regionals JR i el Narita Express. Comprar des d'Espanya és molt més barat. Per 23 dies amb desplaçaments llargs: 21-day pass (~€650/persona). Validar el primer dia d'ús, no el dia de compra.
      </p>
    </div>

    <div class="divider"></div>

    <section>
      <p class="label" style="margin-bottom: 2rem;">Etapes</p>
      {etapes.map((e) => (
        <div style="display: grid; grid-template-columns: 80px 1fr; gap: 1.5rem; padding: 1.5rem 0; border-bottom: 1px solid var(--color-border);">
          <div>
            <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-accent); letter-spacing: 0.04em;">{e.data}</p>
            <span class:list={['tag', { accent: e.tipus === 'destinació' }]} style="margin-top: 0.5rem;">
              {e.tipus}
            </span>
          </div>
          <div>
            <h3 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem;">{e.lloc}</h3>
            <p style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.65;">{e.notes}</p>
          </div>
        </div>
      ))}
    </section>

    <div class="divider"></div>

    <section>
      <p class="label" style="margin-bottom: 1.5rem;">Consells generals de transport</p>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border);">
        <div class="card" style="background: var(--color-bg); pointer-events: none;">
          <h4 style="font-size: 1rem; margin-bottom: 0.75rem;">IC Card (Suica o Pasmo)</h4>
          <p style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.65;">
            Targeta recàrregable per metro, autobús i compres a convenience stores. Descarregar l'app Suica a iOS/Android i configurar-la amb Apple Pay o Google Pay. Elimina la necessitat de comprar bitllets.
          </p>
        </div>
        <div class="card" style="background: var(--color-bg); pointer-events: none;">
          <h4 style="font-size: 1rem; margin-bottom: 0.75rem;">SIM o eSIM</h4>
          <p style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.65;">
            Comprar eSIM de dades il·limitades abans de sortir (IIJmio, Ubigi, Airalo). Dades il·limitades ~€25/mes. Les trucades es fan via WhatsApp. Imprescindible per Google Maps i traducció de kanji amb la càmera.
          </p>
        </div>
        <div class="card" style="background: var(--color-bg); pointer-events: none;">
          <h4 style="font-size: 1rem; margin-bottom: 0.75rem;">Taxi vs Metro</h4>
          <p style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.65;">
            Taxis cars però puntuals i nets. Usar Uber Japan o GO (app japonesa) per no tenir problemes de comunicació. Metro és molt més eficient i barat per distàncies urbanes.
          </p>
        </div>
        <div class="card" style="background: var(--color-bg); pointer-events: none;">
          <h4 style="font-size: 1rem; margin-bottom: 0.75rem;">Shinkansen</h4>
          <p style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.65;">
            Arribar 10 min abans. Seients reservats (shitei-seki) o lliures (jiyuusha). Amb JR Pass es pot reservar seients sense cost addicional a taquilles JR. Portar maletes grans: no hi ha espai overhead estàndard, reservar espai de maletes a alguns trens.
          </p>
        </div>
      </div>
    </section>

  </div>
</Layout>
