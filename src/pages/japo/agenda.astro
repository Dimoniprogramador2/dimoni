---
import Layout from '../../layouts/Layout.astro';

const tipusColor: Record<string, string> = {
  matsuri: '#fff8f0',
  focs: '#f0f4ff',
  música: '#fff0f0',
  tradició: '#f0fff4',
};

const events = [
  {
    data: "1–31 jul",
    nom: "Gion Matsuri",
    lloc: "Kyoto",
    tipus: "matsuri",
    desc: "El festival més famós del Japó, declarat patrimoni cultural immaterial UNESCO. Tot el mes de juliol, però els moments clau son els desfilades de carrosses (yamaboko junkō): 17 de juliol (Saki Matsuri, 23 carrosses) i 24 de juliol (Ato Matsuri, 10 carrosses). Si estàs a Kyoto el 2–5 d'agost, pots veure els preparatius i l'ambient final del festival."
  },
  {
    data: "24–25 jul",
    nom: "Tenjin Matsuri",
    lloc: "Osaka",
    tipus: "matsuri",
    desc: "Un dels tres grans festivals del Japó. Processó de 100+ barques il·luminades pel riu Okawa, seguida d'un espectacle de focs artificials gegant. Nosaltres arribem a Osaka el 6 d'agost, però és important saber que el festival ja haurà passat."
  },
  {
    data: "25 jul",
    nom: "Sumida River Fireworks (隅田川花火大会)",
    lloc: "Tokyo / Asakusa",
    tipus: "focs",
    desc: "El festival de focs artificials més gran i antic de Tokyo. Més de 20.000 coets llançats des dels dos costats del riu Sumida, prop d'Asakusa. Data: darrer dissabte de juliol → 25 de juliol de 2026. Nosaltres ja serem a Tokyo (arribo el 26). Si podem ajustar l'agenda, val molt la pena ser-hi. Arribar a Asakusa aviat (15h) per trobar lloc. Reservar restaurant amb vistes al riu amb molta antelació."
  },
  {
    data: "2–5 ago",
    nom: "Koenji Awa Odori",
    lloc: "Tokyo / Koenji",
    tipus: "matsuri",
    desc: "Una de les millors versions de la dansa Awa Odori fora de Tokushima. Barri de Koenji, accessible en metro. 12.000 ballarins al carrer. Gratuït. Si coincideix amb la nostra estada a Tokyo (tenim els dies 26 jul–1 ago i 10–13 ago), caldrà verificar dates exactes de 2026."
  },
  {
    data: "1–2 ago",
    nom: "Number Shot Festival",
    lloc: "Fukuoka (Kyushu)",
    tipus: "música",
    desc: "El festival de música més gran del Kyushu. Al Mizuho PayPay Dome de Fukuoka. Fora de la nostra ruta però esmentat per si es considera una extensió al sud del Japó."
  },
  {
    data: "11–15 ago",
    nom: "Awa Odori (Tokushima)",
    lloc: "Tokushima (Shikoku)",
    tipus: "matsuri",
    desc: "El festival de dansa més gran del Japó. 1.3 milions d'espectadors. Dates coincideixen amb la nostra tornada a Tokyo (10–13 ago) però Tokushima és a Shikoku, fora de ruta."
  },
  {
    data: "14–16 ago",
    nom: "Summer Sonic 2026",
    lloc: "Tokyo (Chiba) i Osaka",
    tipus: "música",
    desc: "Un dels festivals de música més importants del Japó. Celebra el 25è aniversari en 2026. Dates: 14–16 d'agost. El nostre vol de tornada és el 14 d'agost: si coincideix amb l'horari, l'últim dia podria ser possible. Artistes de primer nivell (line-up anunciat cada primavera). Verificar dates exactes i artistes quan s'anunciïn."
  },
  {
    data: "Tot agost",
    nom: "Bon Festival / Obon (お盆)",
    lloc: "Tot el Japó",
    tipus: "tradició",
    desc: "Festival budista on els japonesos recorden els avantpassats. El 13–16 d'agost és el moment central. Molts japonesos viatgen a casa seva, els trens i aeroports s'anomenen molt. Els cementiris s'il·luminen amb llanternes. Als pobles s'organitzen danses Bon Odori. Molt bonica però implica molta gent als transports."
  },
  {
    data: "Tot juliol–agost",
    nom: "Focs artificials (hanabi taikai)",
    lloc: "Tot el Japó",
    tipus: "focs",
    desc: "L'estiu japonès és la temporada de festivals de focs artificials. A part del Sumida, hi ha hanabi a gairebé totes les ciutats. A Tokyo: Edogawa Fireworks (agost), Adachi Fireworks (agost). A Osaka: Naniwa Yodogawa Fireworks (últim dissabte de juliol). Consultar Time Out Tokyo i Time Out Osaka per dates exactes 2026."
  },
  {
    data: "Tot estiu",
    nom: "Stadiums Tour / Concerts",
    lloc: "Tokyo, Osaka, Nagoya",
    tipus: "música",
    desc: "L'estiu japonès concentra tours dels grans artistes internacionals. El Saitama Super Arena (prop de Tokyo) i el Osaka-jo Hall son els grans venues. Consultar: LiveNation Japan, PIA (tickets), e+. Els concerts internacionals solen anunciar-se amb 2–4 mesos d'antelació."
  }
];
---
<Layout title="Agenda cultural" description="Festivals, concerts i events al Japó juliol–agost 2026" section="japo">
  <div class="container" style="padding-top: 4rem; padding-bottom: 6rem;">

    <nav style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 3rem; font-size: 0.8125rem; color: var(--color-muted);">
      <a href="/japo" style="color: var(--color-muted);">Japó</a>
      <span>→</span>
      <span style="color: var(--color-fg);">Agenda</span>
    </nav>

    <p class="label" style="margin-bottom: 1.25rem;">Juliol – Agost 2026 · Festivals i cultura</p>
    <h1 style="font-size: clamp(2.5rem, 7vw, 4.5rem); margin-bottom: 1.5rem;">Agenda cultural</h1>
    <p style="font-size: 1.0625rem; color: var(--color-muted); max-width: 560px; margin-bottom: 3rem;">
      L'estiu japonès és la temporada de festivals (matsuri), focs artificials (hanabi) i bon temps musical. Juliol–agost és quan el Japó celebra la vida a la nit per escapar de la calor del dia.
    </p>

    <div class="info-block neutral" style="margin-bottom: 3rem;">
      <p style="font-size: 0.875rem; color: var(--color-muted);">
        <strong>Com comprar entrades:</strong> Per a concerts i festivals de pagament, les plataformes principals al Japó son <strong>e+ (eplus.jp)</strong>, <strong>Pia</strong> i <strong>Lawson Ticket</strong>. Molts requereixen una adreça japonesa per al lliurament. Alternativa: comprar a través de <strong>Voyagin</strong> o <strong>Klook</strong>, que serveixen a estrangers. Per a matsuri i focs artificials, l'entrada és normalment gratuïta.
      </p>
    </div>

    <div class="divider"></div>

    <div style="border: 1px solid var(--color-border);">
      {events.map((e, i) => (
          <div style={`display: grid; grid-template-columns: 100px 1fr; gap: 1.5rem; padding: 1.25rem; border-bottom: 1px solid var(--color-border); background: ${tipusColor[e.tipus] || 'var(--color-bg)'}; ${i === events.length - 1 ? 'border-bottom: none;' : ''}`}>
            <div>
              <p style="font-size: 0.75rem; font-weight: 700; color: var(--color-accent); margin-bottom: 0.375rem;">{e.data}</p>
              <span class="tag">{e.tipus}</span>
            </div>
            <div>
              <div style="display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 0.375rem;">
                <h3 style="font-size: 1rem; font-weight: 700;">{e.nom}</h3>
                <span style="font-size: 0.75rem; color: var(--color-muted);">{e.lloc}</span>
              </div>
              <p style="font-size: 0.8125rem; color: var(--color-muted); line-height: 1.65;">{e.desc}</p>
            </div>
          </div>
      ))}
    </div>

    <div class="divider"></div>

    <section>
      <p class="label" style="margin-bottom: 1.25rem;">Recursos per a seguiment</p>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border);">
        {[
          { nom: "Time Out Tokyo", url: "timeout.com/tokyo", desc: "El millor recurs en anglès per a events setmanals a Tokyo. Concerts, exposicions, festivals." },
          { nom: "Japan National Tourism (JNTO)", url: "jnto.go.jp", desc: "Calendari oficial de matsuri i events culturals. Actualitzat regularment per temporada." },
          { nom: "e+ (Eplus)", url: "eplus.jp", desc: "La major plataforma de venda d'entrades del Japó. Concerts, esports, musicals. En japonès." },
          { nom: "Voyagin / Klook", url: "klook.com", desc: "Tickets per a estrangers per a events japonesos. Amb servei en anglès i lliurament internacional." },
        ].map(v => (
          <div class="card" style="background: var(--color-bg); pointer-events: none;">
            <h4 style="font-size: 0.9375rem; font-weight: 700; margin-bottom: 0.25rem;">{v.nom}</h4>
            <p style="font-size: 0.75rem; color: var(--color-accent); margin-bottom: 0.5rem;">{v.url}</p>
            <p style="font-size: 0.8125rem; color: var(--color-muted); line-height: 1.65;">{v.desc}</p>
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>
