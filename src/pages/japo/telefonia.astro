---
import Layout from '../../layouts/Layout.astro';

const sony = [
  {
    ref: "Xperia 1 VII",
    nom: "Sony Xperia 1 VII",
    preu: "¥198,000",
    euros: "~€1,200",
    europa: "~€1,499",
    estalvi: "~20%",
    desc: "El flagship de Sony per a 2026. Pantalla OLED 4K HDR de 6,5\", 120Hz. Sistema de càmera codesenyat amb Alpha: sensor 1 polzada, Zeiss T*, zoom peristàltic. Audio Hi-Res 3.5mm. La càmera de mòbil més fotogràfica del mercat, pel que diuen els fotògrafs professionals.",
    tag: "Flagship",
    exclusiu: false
  },
  {
    ref: "Xperia 5 VII",
    nom: "Sony Xperia 5 VII",
    preu: "¥132,000",
    euros: "~€800",
    europa: "~€1,049",
    estalvi: "~24%",
    desc: "El compacte d'alta gamma. Pantalla OLED 6,1\", format 21:9 (ideal per a vídeo). El mateix sistema de càmera que l'1 VII però en cos petit. Per a qui vol totes les funcions pro sense el format gran.",
    tag: "Compacte",
    exclusiu: false
  },
  {
    ref: "Xperia 10 VII",
    nom: "Sony Xperia 10 VII",
    preu: "¥62,000",
    euros: "~€375",
    europa: "~€499",
    estalvi: "~25%",
    desc: "El mig gamma de Sony. Pantalla OLED 6,1\", bateria gran, càrrega ràpida. Lleuger i prim. Per a ús quotidià sense excesos. L'alternativa Sony a l'iPhone 15 / Pixel 8a en qualitat i durada de bateria.",
    tag: "Gamma mitjana",
    exclusiu: false
  },
  {
    ref: "Xperia 1 VII Professional",
    nom: "Xperia 1 VII Pro",
    preu: "¥275,000",
    euros: "~€1,665",
    europa: "~€2,199",
    estalvi: "~24%",
    desc: "Versió per a creadors de contingut. Streaming en directe integrat, monitor extern per a la càmera, monitor de so en temps real. Entrada HDMI i USB Audio. El mòbil dels cineastes i streamers professionals.",
    tag: "Pro",
    exclusiu: false
  },
];

const japonesos = [
  {
    ref: "Sharp Aquos R9 Pro",
    nom: "Sharp Aquos R9 Pro",
    preu: "¥198,000",
    euros: "~€1,200",
    europa: "No disponible",
    desc: "Pantalla IGZO OLED 6,45\", 240Hz. Sistema de càmera Leica. El primer mòbil Sharp d'alta gamma pensant en el mercat internacional, però de moment exclusiu JDM. Disseny molt japonès: prim, net, sense gimmicks.",
    tag: "Exclusiu JDM"
  },
  {
    ref: "Sharp Aquos sense9",
    nom: "Sharp Aquos sense9",
    preu: "¥52,000",
    euros: "~€315",
    europa: "No disponible",
    desc: "El mig gamma de Sharp, molt popular al Japó per la bateria (5.000 mAh) i la pantalla IGZO eficient. El mòbil de la gent gran i dels treballadors de camp. Resistència IP68. Preu accessible i molt fiable.",
    tag: "Exclusiu JDM"
  },
  {
    ref: "Fujitsu Arrows We2 Plus",
    nom: "Fujitsu Arrows We2 Plus",
    preu: "¥58,000",
    euros: "~€350",
    europa: "No disponible",
    desc: "El mòbil dels funcionaris i treballadors japonesos. Disseny austere, bateria recanviable per l'usuari (molt rar en 2026), resistència MIL-STD. Alguns models porten lector d'iris. Curiós document de com el Japó dissenya per a la durabilitat.",
    tag: "Exclusiu JDM"
  },
  {
    ref: "Kyocera DuraForce Pro 3",
    nom: "Kyocera DuraForce Pro",
    preu: "¥75,000",
    euros: "~€455",
    europa: "~€900",
    estalvi: "~50%",
    desc: "El ruggerized japonès. MIL-STD-810H, IP68, pantalla funcionant amb guants o mullada. Bateria enorme, connector ptt lateral. Per a emergències, construcció, muntanya. Al Japó el venen a la meitat del que val a Europa.",
    tag: "Ruggerized"
  },
];

const avisos = [
  {
    titol: "Bandes de xarxa",
    text: "Els mòbils japonesos suport 4G/5G en les bandes japoneses (B1, B3, B19, B21, B28...). La majoria de bandes 4G principals funcionen a Europa. Per a 5G, verifica que inclogui les bandes n78/n1 europees. Les Xperia internacionals ja les inclouen; els Sharp/Fujitsu exclusius JDM potser no."
  },
  {
    titol: "SIM lock",
    text: "Molts mòbils venuts per DoCoMo, au o SoftBank vénen SIM-locked per a la seva xarxa. Per evitar-ho: compra al mercat lliure (SIMフリー, «SIM-free»), a Yodobashi o Amazon JP. Els SIM-free es poden usar amb qualsevol SIM espanyola."
  },
  {
    titol: "Idioma i Google",
    text: "Els mòbils japonesos vénen en japonès per defecte, però Android permet canviar a qualsevol idioma. Google Play i totes les apps estàndard funcionen igual. Algunes apps bancàries japoneses detecten el país i no es poden instal·lar, però les europees funcionen sense problemes."
  },
  {
    titol: "Garantia i reparacions",
    text: "La garantia dels fabricants japonesos no és vàlida a Espanya. Sony Espanya pot reparar Xperia comprats al Japó però no cobert per garantia de fàbrica. Els Sharp i Fujitsu no tenen servei tècnic a Europa. Compra protecció addicional o coneix el risc."
  },
  {
    titol: "Tax-free",
    text: "Yodobashi Camera, Bic Camera i Yamada Denki apliquen tax-free (10%) amb passaport. Per a un Xperia 1 VII a ¥198,000 l'estalvi addicional del tax-free és de ¥18,000 (~€110). El preu final es marca al rebut amb el descàrrec."
  },
  {
    titol: "FeliCa (Suica al mòbil)",
    text: "Molts mòbils japonesos porten FeliCa, el NFC japonès per a pagaments i transport. Permet carregar la targeta Suica directament al mòbil. Les Xperia de la sèrie japonesa sí en porten; les internacionals no. Els Sharp i Fujitsu sempre el porten."
  },
];
---
<Layout title="Telèfons mòbils al Japó — Sony Xperia, Sharp, preus JDM" description="Comprar mòbils al Japó: Xperia, Sharp Aquos, Fujitsu Arrows. Preus i diferencial vs Europa" section="japo">
  <div class="container" style="padding-top: 4rem; padding-bottom: 6rem;">

    <nav style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 3rem; font-size: 0.8125rem; color: var(--color-muted);">
      <a href="/japo" style="color: var(--color-muted);">Japó</a>
      <span>→</span>
      <span style="color: var(--color-fg);">Telefonia</span>
    </nav>

    <p class="label" style="margin-bottom: 1.25rem;">Tecnologia · Telefonia</p>
    <h1 style="font-size: clamp(2.5rem, 7vw, 4.5rem); margin-bottom: 1.5rem;">Mòbils al Japó</h1>
    <p style="font-size: 1.0625rem; color: var(--color-muted); max-width: 600px; margin-bottom: 1.5rem; line-height: 1.75;">
      El Japó és un dels mercats de telefonia més singulars del món: Sony Xperia és rei, Sharp fabrica per al mercat local amb tecnologia puntera, i Fujitsu produeix mòbils pràcticament desconeguts a Europa. Amb el ien dèbil, les Xperia costen un 20–25% menys que a Espanya.
    </p>
    <div style="display: inline-flex; gap: 2rem; padding: 1rem 1.5rem; background: var(--color-subtle); border: 1px solid var(--color-border); margin-bottom: 3rem;">
      <div>
        <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-muted); margin-bottom: 0.25rem;">ESTALVI XPERIA</p>
        <p style="font-size: 1.5rem; font-weight: 800; color: var(--color-accent);">20–25%</p>
      </div>
      <div style="width: 1px; background: var(--color-border);"></div>
      <div>
        <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-muted); margin-bottom: 0.25rem;">TAX-FREE</p>
        <p style="font-size: 1.5rem; font-weight: 800; color: var(--color-fg);">+10%</p>
      </div>
      <div style="width: 1px; background: var(--color-border);"></div>
      <div>
        <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-muted); margin-bottom: 0.25rem;">EXCLUSIUS JDM</p>
        <p style="font-size: 1.5rem; font-weight: 800; color: var(--color-fg);">Sharp · Fujitsu</p>
      </div>
    </div>

    <div class="divider"></div>

    <section style="margin-bottom: 4rem;">
      <div style="display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 0.75rem;">
        <h2 style="font-size: 1.75rem;">Sony Xperia</h2>
        <span class="label">La sèrie japonesa de Sony · Disponible a Europa</span>
      </div>
      <p style="font-size: 0.9375rem; color: var(--color-muted); margin-bottom: 2rem; max-width: 640px; line-height: 1.7;">
        Les Xperia de la sèrie japonesa (SIMフリー) funcionen perfectament a Espanya. Comprant-les al Japó s'estalvia entre un 20 i un 30% respecte al preu europeu oficial, més el tax-free del 10%. Verifica que sigui la versió SIM-free i no la versió de DoCoMo o au.
      </p>

      <div style="border: 1px solid var(--color-border);">
        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; padding: 0.5rem 1.25rem; border-bottom: 1px solid var(--color-border); background: var(--color-subtle);">
          <span style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-muted);">MODEL</span>
          <span style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-muted);">PREU JAPÓ</span>
          <span style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-muted);">PREU EUROPA</span>
          <span style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-accent);">ESTALVI</span>
        </div>
        {sony.map((m, i) => (
          <div style={`display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; padding: 1rem 1.25rem; border-bottom: 1px solid var(--color-border); align-items: start; ${i === sony.length - 1 ? 'border-bottom: none;' : ''}`}>
            <div>
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.25rem;">
                <span style="font-size: 0.9375rem; font-weight: 700;">{m.nom}</span>
                <span class:list={['tag', { accent: m.tag === 'Flagship' }]}>{m.tag}</span>
              </div>
              <p style="font-size: 0.75rem; color: var(--color-muted); line-height: 1.5;">{m.desc}</p>
            </div>
            <span style="font-size: 0.875rem; font-weight: 700; color: var(--color-accent); padding-top: 0.125rem;">{m.euros}<br/><span style="font-size: 0.7rem; color: var(--color-muted); font-weight: 400;">{m.preu}</span></span>
            <span style="font-size: 0.875rem; color: var(--color-muted); padding-top: 0.125rem;">{m.europa}</span>
            <span style="font-size: 0.9375rem; font-weight: 800; color: var(--color-accent); padding-top: 0.125rem;">{m.estalvi}</span>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <section style="margin-bottom: 4rem;">
      <div style="display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 0.75rem;">
        <h2 style="font-size: 1.75rem;">Exclusius japonesos</h2>
        <span class="label">Sharp · Fujitsu · Kyocera</span>
      </div>
      <p style="font-size: 0.9375rem; color: var(--color-muted); margin-bottom: 2rem; max-width: 640px; line-height: 1.7;">
        Marques gairebé inexistents a Europa, però dominants en certs nínxols del mercat japonès. Pantalles IGZO (Sharp), bateries recanviables (Fujitsu), ruggerized (Kyocera). La telefonia japonesa té una lògica pròpia molt diferent a l'occidental.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border);">
        {japonesos.map(m => (
          <div style="background: var(--color-bg); padding: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.25rem;">
              <h3 style="font-size: 1rem; font-weight: 700;">{m.nom}</h3>
              <span class="tag">{m.tag}</span>
            </div>
            <div style="display: flex; gap: 1rem; align-items: baseline;">
              <span style="font-size: 1rem; font-weight: 800; color: var(--color-accent);">{m.euros}</span>
              <span style="font-size: 0.75rem; color: var(--color-muted);">{m.preu}</span>
              {m.europa && <span style="font-size: 0.75rem; color: var(--color-muted);">· Europa: {m.europa}</span>}
            </div>
            <p style="font-size: 0.8125rem; color: var(--color-muted); line-height: 1.65; flex: 1;">{m.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <section style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1.5rem;">Avisos pràctics</h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border);">
        {avisos.map(a => (
          <div style="background: var(--color-bg); padding: 1.5rem;">
            <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.5rem;">{a.titol.toUpperCase()}</p>
            <p style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.65;">{a.text}</p>
          </div>
        ))}
      </div>
    </section>

    <section>
      <div style="padding: 1.5rem; background: var(--color-subtle); border: 1px solid var(--color-border);">
        <p class="label" style="margin-bottom: 0.75rem;">On comprar</p>
        <p style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.75; max-width: 700px;">
          <strong>Yodobashi Camera Akihabara</strong>: la major selecció, tax-free, personal que parla anglès a la secció de mòbils. <strong>Bic Camera Yurakucho</strong>: molt gran, bon assortiment SIM-free. <strong>Amazon JP</strong> (amb Buyee): per comparar preus i trobar models venuts per particulars. <strong>Mercari JP</strong>: segon mà japonès, com a nou però molt més barat. Busca 「SIMフリー」(SIM-free) per filtrar els que funcionen amb qualsevol SIM.
        </p>
      </div>
    </section>

  </div>
</Layout>
