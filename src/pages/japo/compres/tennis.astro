---
import Layout from '../../../layouts/Layout.astro';

const yonexRaquetes = [
  {
    model: "VCORE Pro 97",
    codi: "VCP97",
    cap: "97 in²",
    pes: "310 g",
    desc: "La raqueta dels jugadors agressius. Perfil prim (22mm) per a màxim control i rotació. Usada per Carlo Alcaraz i múltiples ATP Top-50. La versió japones inclou colors i customitzacions exclusives. Millor compra si ets jugador tècnic de nivell avançat.",
    preu: "¥33,000–42,000",
    euros: "~€200–€255",
