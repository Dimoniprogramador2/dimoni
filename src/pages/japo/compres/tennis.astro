const ontrobars = [
  { nom: "Yonex Badminton & Tennis Center", barri: "Bunkyo · Tokyo", desc: "La botiga oficial de Yonex prop de les oficines centrals. Catàleg complet de raquetes, cordes, roba i sabates. Servei de cordatge (encordament) in situ. Possibilitat de provar raquetes amb cordatge propi.", nota: "Metro: Korakuen / Kasuga" },
  { nom: "Alpen Sports (secció tenis)", barri: "Diverses ubicacions", desc: "La cadena multimarca japonesa més gran. Yonex, Wilson, Babolat, Head, Dunlop, Mizuno tots junts. Comparació real de productes. Descomptes importants al juliol per estoc de temporada anterior.", nota: "Sales de juliol fins al 40%" },
  { nom: "Super Sports Xebio", barri: "Diverses ubicacions · Tokyo/Osaka", desc: "Cadena esportiva japonesa. Bona secció de tenis amb assessors. Preus lleugerament inferiors als d'Alpen en algunes marques. Servei de cordatge disponible a les botigues grans.", nota: "Tax-free a partir de ¥5,000" },
  { nom: "Tennis Shop Lala Shinjuku", barri: "Shinjuku · Tokyo", desc: "Botiga especialitzada en tenis. Assessorament expert, tot el catàleg Yonex, possibilitat de provar raquetes. L'equivalent d'una botiga especialitzada de referència, amb l'amplitud de catàleg japonès.", nota: "Especialitzada en Yonex" },
