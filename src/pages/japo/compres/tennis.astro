const preusComparatius = [
  { producte: "Raqueta Yonex VCORE Pro 97",     japo: "¥33,000–42,000",  euros: "~€200–€255", europa: "€230–€300", estalvi: "~15–25%", nota: "Colorways exclusius japonesos. Possibilitat de personalització a botigues especialitzades." },
  { producte: "Raqueta Yonex EZONE 98",         japo: "¥30,000–38,000",  euros: "~€182–€230", europa: "€200–€260", estalvi: "~15–20%", nota: "La més venuda a Japan. Stock ampli a totes les cadenes esportives." },
  { producte: "Raqueta Yonex Percept 97",       japo: "¥38,000–46,000",  euros: "~€230–€279", europa: "€240–€320", estalvi: "~15–25%", nota: "Model recent. Molt difícil de trobar a Europa; aquí disponible a catàleg complet." },
  { producte: "Raqueta Dunlop CX 400 Tour",     japo: "¥25,000–35,000",  euros: "~€152–€212", europa: "€180–€250", estalvi: "~15–20%", nota: "Dunlop és ara japonesa (Sumitomo). El catàleg domèstic és el més complet del món." },
  { producte: "Sabates Asics Gel-Resolution 9", japo: "¥15,400–19,800",  euros: "~€93–€120",  europa: "€130–€160", estalvi: "~25–35%", nota: "Colorways JDM. Mig número menys que la talla europea habitual." },
  { producte: "Sabates Yonex Power Cushion",    japo: "¥13,200–18,700",  euros: "~€80–€113",  europa: "€130–€170", estalvi: "~30–40%", nota: "Gairebé absent a Europa. Al Japó, disponible a totes les cadenes esportives." },
  { producte: "Roba Yonex (camisa de joc)",     japo: "¥4,400–8,800",    euros: "~€27–€53",   europa: "€50–€90",   estalvi: "~35–45%", nota: "La diferència és molt significativa. Colorways estacionals japonesos." },
  { producte: "Polo Uniqlo Tennis (Federer Ed.)", japo: "¥4,990–6,990",  euros: "~€30–€42",   europa: "€50–€70",   estalvi: "~30–40%", nota: "Disponible globalment però 25–35% més car fora del Japó." },
