    models: "F Tour 310, F Tour 300, F Tour 285",
    preu: "¥18,000–30,000",
    euros: "~€109–€182",
    img: "/img/tennis/mizuno-f-tour.jpg",
    tag: "JDM · Poc conegut",
  },
  {
    nom: "Wilson Japan",
    nom_ja: "ウィルソン",
    empresa: "Distribució Japó: Descente",
    desc: "Wilson al Japó la distribueix Descente (sí, la mateixa marca d'esquí). El catàleg japonès de Wilson inclou colorways exclusius per al mercat local, sobretot a la línia Ultra i Blade. Preus similars als europeus però amb el 10% de tax-free per sobre.",
    models: "Blade 98 v8, Ultra 100, Pro Staff",
    preu: "¥30,000–55,000",
    euros: "~€182–€333",
