    preu: "¥35,000–43,000",
    euros: "~€212–€261",
    img: "/img/tennis/yonex-vcore95.jpg",
    tag: "Control màxim",
    nivell: "Expert",
  },
  {
    model: "Percept 97",
    codi: "PCP97",
    cap: "97 in²",
    pes: "310 g",
    desc: "La generació més recent de Yonex (2023). Tecnologia Elastic Ti que millora la sensació de la pilota en impacte. Combina el confort de l'EZONE amb el control del VCORE Pro. Molt difícil de trobar a Europa; la versió japonesa porta colorways exclusius.",
    preu: "¥38,000–46,000",
    euros: "~€230–€279",
    img: "/img/tennis/yonex-percept97.jpg",
    tag: "Ultima generació",
    nivell: "Mig–Avançat",
  },
  {
    model: "EZONE 100",
    codi: "EZ100",
    cap: "100 in²",
    pes: "300 g",
