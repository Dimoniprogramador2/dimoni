---
import Layout from '../../layouts/Layout.astro';

const descente = [
  {
    linia: "ALLTERRAIN",
    kanji: "オルテライン",
    desc: "La línia tècnica premium. Costums de descens olímpic i jaquetes de freeride amb DERMIZAX NX (impermeabilitat 20.000mm, transpirabilitat superior a GORE-TEX en esforç intens). Equipa els nacionals del Japó, Canadà, Alemanya i Corea.",
    preu: "¥80,000–200,000",
    euros: "~€485–€1,210",
    img: "/img/esqui/descente-allterrain.jpg",
    tag: "Competició",
  },
  {
    linia: "S.I.O. Ski In Outfit",
    kanji: "スキーインアウトフィット",
    desc: "La família d'esquí clàssic. Tall japonès molt més cenyit que les marques europees, paleta mineral (blanc neu, carbó, beix). Exclusiu del mercat japonès — no surt a Europa.",
    preu: "¥50,000–120,000",
    euros: "~€305–€730",
    img: "/img/esqui/descente-sio.jpg",
    tag: "Japó exclusiu",
  },
  {
    linia: "× TOMORROWLAND",
    kanji: "デサント × トゥモローランド",
    desc: "Col·laboració amb Tomorrowland. Jaquetes tècniques pensades per ser portades també a la ciutat: talls minimalistes, sense butxaques de valona ni elements tècnics visibles. Molt populars a Hakuba i Niseko.",
    preu: "¥60,000–90,000",
    euros: "~€365–€545",
    img: "/img/esqui/descente-tomorrowland.jpg",
    tag: "Col·laboració",
  },
  {
    linia: "× BEAMS",
    kanji: "デサント × ビームス",
    desc: "Col·laboració amb BEAMS. Paleta de colors expansiva, retro ski aesthetic anys 80–90 japonès. S'esgota la primera setmana de llançament. Gairebé impossible de trobar fora del Japó.",
    preu: "¥40,000–75,000",
    euros: "~€243–€455",
    img: "/img/esqui/descente-beams.jpg",
    tag: "Col·laboració",
  },
  {
    linia: "MOVE SPORT",
    kanji: "ムーブスポーツ",
    desc: "La línia accessible. Midlayer, roba tèrmica i base layer. Preu assequible, qualitat japonesa. A Descente Direct, Alpen Sports i grans superfícies esportives. Sense distribució a Europa.",
    preu: "¥5,000–25,000",
    euros: "~€30–€152",
    img: "/img/esqui/descente-movesport.jpg",
    tag: "Accessible",
  },
];

const altresMarques = [
  {
    nom: "Phenix",
    nom_ja: "フェニックス",
    fundacio: "1952",
    desc: "La segona gran marca d'esquí japonesa. Va equipar l'equip olímpic japonès durant dècades. Especialitat: peces de competició alpí i fons. Menys coneguda que Descente però considerada igual o superior en els cercles tècnics. Les jaquetes Outer Shell porten el teixit PHENIX DERMIZAX, propi de la marca.",
    preu: "¥45,000–130,000",
    euros: "~€273–€788",
    img: "/img/esqui/phenix-jacket.jpg",
    on: "Phenix direct stores, Alpen Sports, Victoria Sports",
    tag: "Alta tècnica",
  },
  {
    nom: "Goldwin",
    nom_ja: "ゴールドウィン",
    fundacio: "1950",
    desc: "Empresa matriu de The North Face Japó. Per al seu propi nom fa roba d'esquí de competició (equip olímpic de combinada alpina) i peces de muntanya avançades. Fora del Japó, quasi invisible. Les seves peces de velocitat (super-G, downhill) s'usen a copa del món.",
    preu: "¥60,000–180,000",
    euros: "~€364–€1,091",
    img: "/img/esqui/goldwin-competition.jpg",
    on: "Goldwin flagship Harajuku, botigues de muntanya especialitzades",
    tag: "Competició",
