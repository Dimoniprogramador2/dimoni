    nom_ja: "オンヨネ",
    fundacio: "1967",
    desc: "Especialistes en esquí de competició alpí i de fons. L'equip japonès de cross-country és Onyone. No fan moda: fan rendiment. Difícil de trobar fora d'Hokkaido i els Alps japonesos. Preus més moderats que Descente per qualitat equivalent.",
    preu: "¥25,000–80,000",
    euros: "~€152–€485",
    img: "/img/esqui/onyone-race.jpg",
    on: "Niseko, Hakuba, Sapporo – botigues d'esports especialitzades",
    tag: "Competició",
  },
  {
    nom: "The North Face Japan",
    nom_ja: "ザ・ノース・フェイス",
    fundacio: "1989 (JP)",
    desc: "Goldwin gestiona TNF al Japó amb col·leccions exclusives inexistents a Europa ni als EUA. La línia Purple Label (Nanamica) és moda de carrer pura; Futurelight Japó és ski tècnic. Les peces amb etiqueta interior en kanji estan fetes a Japan factories.",
    preu: "¥15,000–80,000",
    euros: "~€91–€485",
    img: "/img/esqui/tnf-japan-purple.jpg",
    on: "TNF Harajuku, TNF Shibuya, Isetan Shinjuku",
    tag: "Exclusiu JP",
  },
  {
    nom: "Helly Hansen Japan",
    nom_ja: "ヘリーハンセン",
    fundacio: "1983 (JP)",
    desc: "Al Japó porta 40 anys i és considerada marca local. Col·leccions Japan-only amb colors i talls que mai surten a Escandinàvia. Les col·laboracions amb Comme des Garçons i SHIPS assoleixen preus alts al mercat secundari.",
    preu: "¥20,000–65,000",
    euros: "~€121–€394",
    img: "/img/esqui/helly-hansen-japan.jpg",
    on: "Helly Hansen Harajuku, Laforet Harajuku, Alpen Sports",
    tag: "Exclusiu JP",
  },
];

const esquis = [
  {
    nom: "Ogasaka",
    nom_ja: "小賀坂スキー",
    fundacio: "1938 · Nagano",
    desc: "El fabricant d'esquís japonès per excel·lència. Des de Nagano, construeixen esquís de competició per a l'equip nacional japonès i per a clubs de copa del món. El model MC-R (Masters Competition Race) és el buque insígnia. Construcció artesanal amb fibra de vidre i carboni. Venuts directament a les botigues d'esquí de la zona dels Alps japonesos i a algunes cadenes esportives de Tokyo.",
    preu: "¥80,000–180,000",
    euros: "~€485–€1,091",
    img: "/img/esqui/ogasaka-skis.jpg",
    tag: "Competició",
    tipo: "Esquís",
  },
  {
    nom: "Yonex",
    nom_ja: "ヨネックス",
    fundacio: "1946 · Niigata",
    desc: "Coneguts per raquetes de tennis i badminton, però la seva tecnologia de carboni s'aplica des dels anys 90 a esquís i snowboards. Els seus esquís utilitzen NanoMetric Carbon i Nanoscience Resin, tecnologia transferida del tennis. El snowboard Yonex Achse és llegenda entre els esquiadors de neu en pols d'Hokkaido.",
    preu: "¥55,000–120,000",
    euros: "~€334–€727",
    img: "/img/esqui/yonex-snowboard.jpg",
    tag: "Carboni",
    tipo: "Esquís / Snowboard",
  },
  {
    nom: "Moss Snowstick",
    nom_ja: "モス スノースティック",
    fundacio: "1984 · Hokkaido",
    desc: "La marca de snowboard japonesa de culte a nivell mundial. Fundada a Hokkaido per riders que volien surfar la neu en pols profunda de Niseko. Les seves taules de perfil ample i flex suau definiren el freeride nipó. Cada taula és feta a mà; l'espera pot ser de mesos. Imprescindible si l'objectiu és surfejar els 15 metres de neu anual de Niseko.",
    preu: "¥100,000–160,000",
    euros: "~€606–€970",
    img: "/img/esqui/moss-snowstick.jpg",
    tag: "Pols · Culte",
    tipo: "Snowboard",
  },
  {
    nom: "011 Artistic",
    nom_ja: "ゼロワンワン",
    fundacio: "1994 · Sapporo",
    desc: "Premium handmade snowboards de Sapporo. Especialitzats en pols i freeride. Construcció completament artesanal: cada taula la signa el constructor. Fan col·laboracions amb artistes japonesos que les converteixen en peces de col·leccionista. Distribució quasi exclusivament al Japó i via webs de riders.",
    preu: "¥80,000–130,000",
    euros: "~€485–€788",
    img: "/img/esqui/011-artistic.jpg",
    tag: "Artesà · Sapporo",
    tipo: "Snowboard",
  },
];

const internacionals = [
  { nom: "Burton Japan", nota: "Col·leccions Japan Team Series i colorways exclusius. Burton és la marca de snowboard dominant al Japó. ¥70,000–180,000 (~€424–€1,091). Flagship a Harajuku.", euros: "~€424–€1,091" },
  { nom: "Salomon / Atomic", nota: "Rang complet disponible al Japó sovint al 10–15% menys que a Europa. Algunes versions JDM dels esquís Alpine amb gràfics exclusius per al mercat japonès.", euros: "~€300–€1,000" },
  { nom: "K2 Japan", nota: "Models amb gràfics exclusius JDM. Preus similars a Europa però les cadenes esportives japoneses fan sales de final de temporada amb fins al 40% de descompte.", euros: "~€350–€900" },
  { nom: "Head / Fischer", nota: "Preus pràcticament idèntics a Europa. L'avantatge al Japó és el tax-free del 10%. Si ja tenies previst comprar a Europa, aquí surt una mica més barat.", euros: "~€400–€1,200" },
];

const preusComparatius = [
  { producte: "Jaqueta Descente ALLTERRAIN",       japo: "¥80,000–120,000",  euros: "~€485–€727",  europa: "€900–1,400",   estalvi: "~35–45%", nota: "No disponible a Europa. Compra exclusiva al Japó." },
  { producte: "Jaqueta Phenix Outer Shell (DERMIZAX)", japo: "¥55,000–90,000", euros: "~€334–€545", europa: "€600–1,000",   estalvi: "~25–35%", nota: "Distribució molt limitada a Europa. Catàleg japonès 3× més ampli." },
  { producte: "Pantalons d'esquí tècnics (JP)",    japo: "¥40,000–70,000",   euros: "~€243–€424",  europa: "€450–800",    estalvi: "~25–30%", nota: "Tax-free aplicable des de ¥5,000 en un sol establiment." },
  { producte: "Base layer tèrmic Descente / Phenix", japo: "¥8,000–18,000",  euros: "~€49–€109",   europa: "€90–200",     estalvi: "~20–25%", nota: "La varietat japonesa és molt superior a l'europea." },
  { producte: "Guants d'esquí tècnics (Goldwin)",  japo: "¥12,000–35,000",   euros: "~€73–€212",   europa: "€130–380",    estalvi: "~20–30%", nota: "Goldwin fabrica guants de competició que no arriben a Europa." },
  { producte: "Esquís Ogasaka (carving)",          japo: "¥80,000–150,000",  euros: "~€485–€909",  europa: "—",           estalvi: "100%",    nota: "No distribuïts a Europa. Única forma de compra: directament al Japó." },
  { producte: "Snowboard Moss Snowstick",          japo: "¥100,000–160,000", euros: "~€606–€970",  europa: "€900–1,400",  estalvi: "~25–35%", nota: "Alguna distribució puntual a Europa però a preu molt superior." },
  { producte: "Snowboard / esquí Yonex",          japo: "¥55,000–120,000",  euros: "~€334–€727",  europa: "€500–1,000",  estalvi: "~20–30%", nota: "Distribució occidental molt limitada. Al Japó, catàleg complet." },
];

const ontrobars = [
  { nom: "Descente Tokyo Flagship", barri: "Harajuku · Omotesando", desc: "La botiga principal de Descente. Dues plantes: ALLTERRAIN, Move Sport, col·laboracions actives. Personal especialitzat. Tax-free.", temporada: "Col·lecció esquí: setembre–octubre" },
  { nom: "Alpen Sports (multimarca)", barri: "Diverses ubicacions", desc: "La cadena esportiva japonesa més gran. Descente, Phenix, Onyone, Ogasaka, Head, Atomic tots junts. Descomptes de fi de temporada (febrer–març) del 30–50%.", temporada: "Millors preus: febrer–març" },
  { nom: "Victoria Sports Shinjuku", barri: "Shinjuku · Tokyo", desc: "6 plantes. Secció d'esquí a les plantes superiors amb assessors especialitzats. Estoc d'hivern anterior amb descompte al juliol.", temporada: "Estoc rebaixat: juliol" },
  { nom: "Botigues a peu de pista", barri: "Niseko / Hakuba", desc: "A les estacions d'esquí japoneses hi ha botigues de Descente, Onyone i Ogasaka a preus directes. Si el viatge inclou esquí al Japó, aquí trobes el millor preu i la millor assessoria.", temporada: "Temporada: desembre–abril" },
];
---
<Layout title="Roba d'esquí japonesa" description="Descente, Phenix, Goldwin, Onyone, Ogasaka, Moss Snowstick: marques japoneses d'esquí i snowboard, preus i on comprar" section="japo">
  <div class="container" style="padding-top: 4rem; padding-bottom: 6rem;">

    <nav style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 3rem; font-size: 0.8125rem; color: var(--color-muted);">
      <a href="/japo" style="color: var(--color-muted);">Japó</a>
      <span>→</span>
      <span style="color: var(--color-fg);">Roba d'esquí i material</span>
    </nav>

    <p class="label" style="margin-bottom: 1.25rem;">Compres · Roba tècnica i material</p>
    <h1 style="font-size: clamp(2.5rem, 7vw, 4.5rem); margin-bottom: 1.5rem;">Roba d'esquí japonesa</h1>
    <p style="font-size: 1.0625rem; color: var(--color-muted); max-width: 640px; margin-bottom: 2rem; line-height: 1.75;">
      El Japó és un dels fabricants de roba d'esquí tècnica i material de neu més avançats del món. Descente, Phenix o Goldwin equipes equips olímpics de mitja dotzena de països; Ogasaka i Moss Snowstick construeixen a mà material que no arriba mai a Europa. Preus entre un 25 i un 45% inferiors als europeus.
    </p>
    <p style="font-size: 0.9375rem; color: var(--color-muted); max-width: 640px; margin-bottom: 3rem; line-height: 1.75;">
      La finestra ideal és setembre–febrer. El viatge és al juliol: les col·leccions noves no hauran entrat, però pot quedar estoc de temporada anterior a preus reduïts (30–50% de descompte) a les cadenes esportives.
    </p>

    <a href="/japo/moda" style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-muted); text-decoration: none; border: 1px solid var(--color-border); padding: 0.5rem 0.875rem; margin-bottom: 2.5rem;">
      ← Moda al Japó · Yukata, dissenyadors, artesania tèxtil
    </a>

    <div class="info-block" style="margin-bottom: 3rem;">
      <p style="font-size: 0.875rem; line-height: 1.7; margin: 0;"><strong>Logística:</strong> Les jaquetes i taules d'esquí ocupen molt. Usa el takkyubin (Yamato Transport) fins a l'aeroport, o envia per EMS des d'una oficina de correus — més barat que l'excés de pes de l'avió. Yamato recull a l'hotel.</p>
    </div>

    <div class="divider"></div>

    <!-- DESCENTE -->
    <section style="margin-bottom: 5rem;">
      <div style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 0.75rem; flex-wrap: wrap;">
        <h2 style="font-size: 1.875rem;">Descente</h2>
        <span style="font-size: 1.25rem; color: var(--color-muted);">デサント</span>
        <span class="tag" style="margin-left: auto;">Fundada 1935 · Osaka</span>
      </div>
      <p style="font-size: 0.9375rem; color: var(--color-muted); margin-bottom: 1rem; max-width: 660px; line-height: 1.75;">
        La marca d'esquí japonesa per excel·lència. Equipa els nacionals de Japó, Canadà, Suïssa, Alemanya i Corea. El teixit DERMIZAX NX supera GORE-TEX en escenaris d'esforç intens (alta transpiració, pressió de neu). A Europa, distribució molt limitada i cara; al Japó, catàleg complet amb col·leccions exclusives.
      </p>
      <p style="font-size: 0.875rem; color: var(--color-muted); margin-bottom: 2.5rem; max-width: 660px; line-height: 1.7;">
        Diferència de preu respecte a Europa: <strong style="color: var(--color-fg);">30–45%</strong>. Preus en euros calculats a ~165 ¥/€ + tax-free del 10%.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border);">
        {descente.map(item => (
          <div style="background: var(--color-bg); display: flex; flex-direction: column;">
            <div style="aspect-ratio: 4/3; background: var(--color-subtle); overflow: hidden; position: relative;">
              <img
                src={item.img}
                alt={`Descente ${item.linia}`}
                style="width: 100%; height: 100%; object-fit: cover;"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div style="display: none; position: absolute; inset: 0; align-items: center; justify-content: center; flex-direction: column; gap: 0.5rem; background: var(--color-subtle);">
                <span style="font-size: 0.625rem; font-weight: 700; letter-spacing: 0.15em; color: var(--color-muted);">DESCENTE</span>
                <span style="font-size: 0.875rem; font-weight: 800; color: var(--color-fg); text-align: center; padding: 0 1rem;">{item.linia}</span>
              </div>
              <span class="tag" style="position: absolute; top: 0.75rem; left: 0.75rem;">{item.tag}</span>
            </div>
            <div style="padding: 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.375rem;">
              <div style="display: flex; align-items: baseline; gap: 0.75rem;">
                <h3 style="font-size: 0.9375rem; font-weight: 800;">DESCENTE {item.linia}</h3>
                <span style="font-size: 0.75rem; color: var(--color-muted);">{item.kanji}</span>
              </div>
              <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                <span style="font-size: 1rem; font-weight: 800; color: var(--color-accent);">{item.euros}</span>
                <span style="font-size: 0.75rem; color: var(--color-muted);">{item.preu}</span>
              </div>
              <p style="font-size: 0.8125rem; color: var(--color-muted); line-height: 1.65; flex: 1;">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="info-block neutral" style="margin-top: 1.5rem;">
        <p style="font-size: 0.875rem; line-height: 1.7; margin: 0;"><strong>On comprar Descente:</strong> Flagship Harajuku (prop de Meiji-dori), Alpen Sports i Victoria Sports. Tax-free des de ¥5,000 en una sola compra. Porta el passaport.</p>
      </div>
    </section>

    <!-- ALTRES MARQUES DE ROBA -->
    <section style="margin-bottom: 5rem;">
      <h2 style="font-size: 1.875rem; margin-bottom: 0.5rem;">Altres marques · Roba</h2>
      <p style="font-size: 0.9375rem; color: var(--color-muted); margin-bottom: 2.5rem; max-width: 640px; line-height: 1.75;">
        Descente no és l'única. El mercat japonès d'esquí tècnic és ric, amb marques de competició i col·leccions exclusives que no arriben als mercats occidentals.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border);">
        {altresMarques.map(m => (
          <div style="background: var(--color-bg); display: flex; flex-direction: column;">
            <div style="aspect-ratio: 4/3; background: var(--color-subtle); overflow: hidden; position: relative;">
              <img
                src={m.img}
                alt={m.nom}
                style="width: 100%; height: 100%; object-fit: cover;"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div style="display: none; position: absolute; inset: 0; align-items: center; justify-content: center; flex-direction: column; gap: 0.35rem; background: var(--color-subtle);">
                <span style="font-size: 0.625rem; font-weight: 700; letter-spacing: 0.15em; color: var(--color-muted);">{m.nom_ja}</span>
                <span style="font-size: 1rem; font-weight: 800; color: var(--color-fg);">{m.nom}</span>
                <span style="font-size: 0.6875rem; color: var(--color-muted);">Est. {m.fundacio}</span>
              </div>
              <span class="tag" style="position: absolute; top: 0.75rem; left: 0.75rem;">{m.tag}</span>
            </div>
            <div style="padding: 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.375rem;">
              <div style="display: flex; align-items: baseline; gap: 0.75rem;">
                <h3 style="font-size: 0.9375rem; font-weight: 800;">{m.nom}</h3>
                <span style="font-size: 0.8125rem; color: var(--color-muted);">{m.nom_ja}</span>
              </div>
              <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                <span style="font-size: 1rem; font-weight: 800; color: var(--color-accent);">{m.euros}</span>
                <span style="font-size: 0.75rem; color: var(--color-muted);">{m.preu}</span>
              </div>
              <p style="font-size: 0.8125rem; color: var(--color-muted); line-height: 1.65; flex: 1;">{m.desc}</p>
              <p style="font-size: 0.75rem; color: var(--color-muted); margin-top: 0.25rem;"><span style="font-weight: 700; color: var(--color-fg);">On: </span>{m.on}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ESQUÍS I SNOWBOARDS -->
    <section style="margin-bottom: 5rem;">
      <h2 style="font-size: 1.875rem; margin-bottom: 0.5rem;">Esquís i snowboards japonesos</h2>
      <p style="font-size: 0.9375rem; color: var(--color-muted); margin-bottom: 2.5rem; max-width: 640px; line-height: 1.75;">
        El material japonès té una llarga tradició i algunes marques (Ogasaka, Moss) són de culte mundial. La neu d'Hokkaido —15m anuals a Niseko— va definir el freeride en pols; el material japonès va seguir la filosofia: ample, lleuger, fet per surfar sobre pols.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border); margin-bottom: 2rem;">
        {esquis.map(e => (
          <div style="background: var(--color-bg); display: flex; flex-direction: column;">
            <div style="aspect-ratio: 4/3; background: var(--color-subtle); overflow: hidden; position: relative;">
              <img
                src={e.img}
                alt={e.nom}
                style="width: 100%; height: 100%; object-fit: cover;"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div style="display: none; position: absolute; inset: 0; align-items: center; justify-content: center; flex-direction: column; gap: 0.35rem; background: var(--color-subtle);">
                <span style="font-size: 0.625rem; font-weight: 700; letter-spacing: 0.15em; color: var(--color-muted);">{e.nom_ja}</span>
                <span style="font-size: 1rem; font-weight: 800; color: var(--color-fg);">{e.nom}</span>
              </div>
              <span class="tag" style="position: absolute; top: 0.75rem; left: 0.75rem;">{e.tag}</span>
              <span style="position: absolute; top: 0.75rem; right: 0.75rem; font-size: 0.6875rem; font-weight: 700; padding: 0.25rem 0.5rem; background: var(--color-bg); color: var(--color-fg);">{e.tipo}</span>
            </div>
            <div style="padding: 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.375rem;">
              <div style="display: flex; align-items: baseline; gap: 0.75rem;">
                <h3 style="font-size: 1rem; font-weight: 800;">{e.nom}</h3>
                <span style="font-size: 0.75rem; color: var(--color-muted);">{e.nom_ja}</span>
              </div>
              <p style="font-size: 0.6875rem; color: var(--color-muted);">{e.fundacio}</p>
              <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                <span style="font-size: 1rem; font-weight: 800; color: var(--color-accent);">{e.euros}</span>
                <span style="font-size: 0.75rem; color: var(--color-muted);">{e.preu}</span>
              </div>
              <p style="font-size: 0.8125rem; color: var(--color-muted); line-height: 1.65; flex: 1;">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="label" style="margin-bottom: 1rem;">Marques internacionals disponibles al Japó</p>
      <div style="border: 1px solid var(--color-border);">
        {internacionals.map((m, i) => (
          <div style={`display: grid; grid-template-columns: 200px 1fr 120px; gap: 1.5rem; align-items: center; padding: 1rem 1.5rem; ${i < internacionals.length - 1 ? 'border-bottom: 1px solid var(--color-border);' : ''}`}>
            <p style="font-size: 0.9375rem; font-weight: 800;">{m.nom}</p>
            <p style="font-size: 0.8125rem; color: var(--color-muted); line-height: 1.6;">{m.nota}</p>
            <p style="font-size: 0.875rem; font-weight: 700; color: var(--color-accent); text-align: right;">{m.euros}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- PREUS COMPARATIUS -->
    <section style="margin-bottom: 5rem;">
      <h2 style="font-size: 1.875rem; margin-bottom: 0.5rem;">Preus · Japó vs. Europa</h2>
      <p style="font-size: 0.9375rem; color: var(--color-muted); margin-bottom: 2rem; max-width: 640px; line-height: 1.75;">
        Preus en euros calculats a ~165 ¥/€ ja incloent el tax-free del 10%. Una jaqueta de ¥100,000 surt per ~€550 nets.
      </p>

      <div style="border: 1px solid var(--color-border);">
        <div style="display: grid; grid-template-columns: 1fr 130px 120px 120px 90px; padding: 0.875rem 1.5rem; border-bottom: 1px solid var(--color-border); background: var(--color-surface);">
          {["Producte", "Japó (¥)", "Japó (€)", "Europa (€)", "Estalvi"].map(h => (
            <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted); text-align: right; first-child: {text-align: left}">{h}</p>
          ))}
        </div>
        {preusComparatius.map((p, i) => (
          <div style={`padding: 1rem 1.5rem; ${i < preusComparatius.length - 1 ? 'border-bottom: 1px solid var(--color-border);' : ''}`}>
            <div style="display: grid; grid-template-columns: 1fr 130px 120px 120px 90px; align-items: baseline; margin-bottom: 0.35rem;">
              <p style="font-size: 0.875rem; font-weight: 700;">{p.producte}</p>
              <p style="font-size: 0.8125rem; color: var(--color-muted); text-align: right;">{p.japo}</p>
              <p style="font-size: 0.875rem; font-weight: 800; color: var(--color-accent); text-align: right;">{p.euros}</p>
              <p style="font-size: 0.8125rem; color: var(--color-muted); text-align: right;">{p.europa}</p>
              <p style="font-size: 0.875rem; font-weight: 700; color: var(--color-fg); text-align: right;">{p.estalvi}</p>
            </div>
            <p style="font-size: 0.75rem; color: var(--color-muted); line-height: 1.5;">{p.nota}</p>
          </div>
        ))}
      </div>

      <div class="info-block" style="margin-top: 1.5rem;">
        <p style="font-size: 0.875rem; line-height: 1.7; margin: 0 0 0.5rem 0;"><strong>Tax-free (2026):</strong> Turistes no residents recuperen el 10% de l'IVA en compres de consum des de ¥5,000 en un sol establiment. Porta el passaport. Les cadenes esportives grans ho gestionen directament a caixa.</p>
        <p style="font-size: 0.875rem; line-height: 1.7; margin: 0;"><strong>Canvi de referència:</strong> ~165 ¥/€. Comprova la cotització real just abans del viatge — ±10 ¥/€ canvia el càlcul significativament.</p>
      </div>
    </section>

    <!-- ON COMPRAR -->
    <section style="margin-bottom: 5rem;">
      <h2 style="font-size: 1.875rem; margin-bottom: 0.5rem;">On comprar</h2>
      <p style="font-size: 0.9375rem; color: var(--color-muted); margin-bottom: 2rem; max-width: 600px; line-height: 1.75;">
        Cada canal té el seu avantatge. Recorda que el viatge és al juliol: flagship stores i cadenes esportives tindran estoc de temporada anterior rebaixat, però no la col·lecció nova.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border);">
        {ontrobars.map(l => (
          <div style="background: var(--color-bg); padding: 1.5rem;">
            <p style="font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 0.35rem;">{l.barri}</p>
            <h3 style="font-size: 1rem; font-weight: 800; margin-bottom: 0.5rem;">{l.nom}</h3>
            <p style="font-size: 0.8125rem; color: var(--color-muted); line-height: 1.65; margin-bottom: 0.625rem;">{l.desc}</p>
            <p style="font-size: 0.75rem; color: var(--color-muted);"><span style="font-weight: 700; color: var(--color-fg);">Temporada: </span>{l.temporada}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- NOTES FINALS -->
    <section>
      <div class="info-block neutral">
        <h3 style="font-size: 1rem; font-weight: 800; margin-bottom: 0.875rem;">Roba i material japonès vs. europeu: diferències reals</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
          <div>
            <p style="font-size: 0.8125rem; font-weight: 700; margin-bottom: 0.5rem;">Avantatges del producte japonès</p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.35rem;">
              {["Talls ajustats, sense excés de material", "Teixits propietaris sovint superiors a GORE-TEX", "Colors i col·leccions exclusius del mercat japonès", "Material de competició olímpica accessible al públic", "Snowboards artesans dissenyats per a neu en pols profunda"].map(t => (
                <li style="font-size: 0.8125rem; color: var(--color-muted);">· {t}</li>
              ))}
            </ul>
          </div>
          <div>
            <p style="font-size: 0.8125rem; font-weight: 700; margin-bottom: 0.5rem;">Consideracions</p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.35rem;">
              {["Talles japoneses: menors que les europees (suma +1 o +2)", "Provar la talla és imprescindible; no comprar sense provar", "Instruccions de neteja en japonès (fotos als símbols)", "Servei post-venda impossible des d'Espanya", "Col·lecció esquí entra a les botigues a partir de setembre"].map(t => (
                <li style="font-size: 0.8125rem; color: var(--color-muted);">· {t}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>
